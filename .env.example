# mcp-youtube — environment configuration
# Copy to `.env` and fill in real values; .env is gitignored.

# ---- Anti-ban / rate limiting ---------------------------------------------
# Random sleep window between calls to fetch_transcript. Keep these
# conservative — YouTube will ban your residential IP if you hammer it.
RATE_LIMIT_MIN_SECONDS=5
RATE_LIMIT_MAX_SECONDS=10

# ---- Default fetch behaviour ----------------------------------------------
DEFAULT_LANGUAGE=en
FALLBACK_LANGUAGES=en-US,en-GB

# ---- Webshare proxy (RESERVED for v0.2 — NOT wired in v0.1) ---------------
# Set both to enable rotating residential proxies via youtube-transcript-api.
# In v0.1 these are read but the proxy is not yet plumbed; the code logs a
# warning so you know fetches are still going through your direct IP.
# WEBSHARE_PROXY_USERNAME=
# WEBSHARE_PROXY_PASSWORD=

# ---- Server settings ------------------------------------------------------
MCP_HOST=0.0.0.0
MCP_PORT=3716
LOG_LEVEL=INFO
LOG_FORMAT=json
